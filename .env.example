# AI Agent Agency - Environment Configuration
# Copy this to .env and update paths for your project
# Usage: source .env (bash) or $env = Get-Content .env | ForEach-Object { $_ -split '=' | ForEach-Object { Set-Variable -Name $args[0] -Value $args[1] } }

# Project root (where your source code lives)
PROJECT_ROOT=C:\Projects\my-project

# Source CSS directory
CSS_SRC_DIR=${PROJECT_ROOT}\src\assets\css

# Source JS directory
JS_SRC_DIR=${PROJECT_ROOT}\src\assets\js

# Public/output directory
PUBLIC_DIR=${PROJECT_ROOT}\public_html

# Resources directory (built assets)
RESOURCES_DIR=${PUBLIC_DIR}\resources

# Agency directory (where agent profiles live)
AGENCY_DIR=${PROJECT_ROOT}\storage\agency

# Agent profiles
AGENTS_DIR=${AGENCY_DIR}\agents

# Audit output directory
AUDITS_DIR=${AGENCY_DIR}\audits

# Audit scripts directory
SCRIPTS_DIR=${PROJECT_ROOT}\scripts\audits

# Agent config file
AGENT_CONFIG=${PROJECT_ROOT}\.config\mcp_agents.json

# Breakpoints config
BREAKPOINTS_CONFIG=${PROJECT_ROOT}\.config\breakpoints.json
