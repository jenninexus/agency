  "schedule": {
    "weekly": {
      "monday": {
        "agent": "vidette",
        "focus": "Video grids, playlist constants, aspect ratios, hover effects",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-video-pages.ps1"
      },
      "tuesday": {
        "agent": "bloggie",
        "focus": "PHP headers, tags, share buttons, YAML/JSON entries",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-blog-posts.ps1"
      },
      "wednesday": {
        "agent": "graphviz",
        "focus": "Color compliance, theme consistency, no white backgrounds",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-theme-consistency.ps1"
      },
      "thursday": {
        "agent": "gamergirl",
        "focus": "Game pages, hub pages, CTAs, hero sections, video sections",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-game-pages.ps1",
        "cross_team_review": true
      },
      "friday": {
        "agent": "all",
        "focus": "Implementation day - fix audit failures before weekend",
        "command": "Implementation based on audit results"
      }
    }
  },

  "universal_rules": [
    "No white backgrounds - Light mode uses lavender (#F9F3FB)",
    "CSS variables over hex codes - Theme-aware always",
    "No inline styles - All styling via CSS classes",
    "Test both themes - Light and dark mode verification",
    "Document changes - Update agent changelog and day file",
    "Run audits - Scripts exist for a reason"
  ],

  "cross_check_protocols": {
    "_note": "How agents should coordinate when making changes",
    "new_blog_post": {
      "lead": "bloggie",
      "checklist": [
        "Bloggie: Verify template compliance (blog-post-template.php)",
        "Bloggie: Check tags exist in tags.json",
        "Vidette: Verify related playlists render correctly",
        "DivineDesign: Confirm layout matches template pattern",
        "GraphViz: Test light/dark theme appearance"
      ],
      "configs_to_check": ["content_tags.json", "mcp_video.json"],
      "audit_script": "scripts/audits/audit-blog-posts.ps1"
    },
    "new_game_page": {
      "lead": "gamergirl",
      "checklist": [
        "GamerGirl: Follow game-page-template.php structure",
        "GamerGirl: Add to playlist-ids.json if new playlist",
        "Vidette: Verify video sections use renderVideos()/renderPlaylists()",
        "DivineDesign: Confirm hero section matches game page pattern",
        "GraphViz: Test steam-gradient and theme colors"
      ],
      "configs_to_check": ["mcp_video.json", "playlist-ids.json"],
      "audit_script": "scripts/audits/audit-game-pages.ps1"
    },
    "video_display_changes": {
      "lead": "vidette",
      "checklist": [
        "Vidette: Update mcp_video.json if adding new display pattern",
        "Vidette: Verify breakpoints.json column presets are used",
        "Vidette: Run audit-video-pages.ps1",
        "DivineDesign: Confirm layout doesn't break page structure",
        "GraphViz: Test video cards in both themes"
      ],
      "configs_to_check": ["mcp_video.json", "breakpoints.json"],
      "audit_script": "scripts/audits/audit-video-pages.ps1"
    },
    "css_changes": {
      "lead": "graphviz",
      "checklist": [
        "GraphViz: Verify changes use CSS variables",
        "GraphViz: Test both light and dark themes",
        "DivineDesign: Confirm layout properties in correct file",
        "Vidette: If media.css changed, verify video cards still work"
      ],
      "configs_to_check": ["breakpoints.json", "assets-deps.json"],
      "build_required": true
    },
    "layout_changes": {
      "lead": "divinedesign",
      "checklist": [
        "DivineDesign: Check breakpoints.json before responsive changes",
        "DivineDesign: Verify page follows template pattern",
        "GraphViz: Confirm no color properties in layout files",
        "Vidette: If video sections affected, run video audit"
      ],
      "configs_to_check": ["breakpoints.json", "PAGES.md"]
    }
  },

